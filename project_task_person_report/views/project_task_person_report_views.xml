<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_person_report_wizard_form" model="ir.ui.view">
        <field name="name">project.task.person.report.wizard.form</field>
        <field name="model">project.task.person.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Open Tasks by Person" create="0" edit="0">
                <header>
                    <button name="action_refresh" type="object" string="Refresh" class="btn-secondary"/>
                    <button name="action_print_pdf" type="object" string="Export PDF" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Open Tasks by Person</h1>
                    </div>
                    <group>
                        <field name="report_date"/>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <list string="Open Tasks by Person" create="0" delete="0" edit="0">
                            <field name="user_id"/>
                            <field name="open_project_count" class="text-primary fw-bold" sum="Total Projects Created"/>
                            <field name="task_created_count" class="text-info fw-bold" sum="Total Tasks Created"/>
                            <field name="open_task_count" class="text-success fw-bold" sum="Total Open Tasks"/>
                            <field name="late_task_count" class="text-danger fw-bold" sum="Total Late Tasks"/>
                            <button
                                name="action_view_late_tasks"
                                type="object"
                                string="View Late Tasks"
                                class="btn-link text-danger"
                                invisible="late_task_count == 0"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_task_person_report_open" model="ir.actions.server">
        <field name="name">Open Tasks by Person</field>
        <field name="model_id" ref="model_project_task_person_report_wizard"/>
        <field name="state">code</field>
        <field name="code">action = env['project.task.person.report.wizard'].action_open_report()</field>
    </record>

    <menuitem
        id="menu_project_task_person_report"
        name="Open Tasks by Person"
        parent="project.menu_project_report"
        action="action_project_task_person_report_open"
        sequence="50"
        groups="project.group_project_user"/>
</odoo>
