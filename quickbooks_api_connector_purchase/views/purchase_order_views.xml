<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_qb" model="ir.ui.view">
        <field name="name">purchase.order.form.qb</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="QuickBooks" name="quickbooks_tab"
                      groups="quickbooks_api_connector.group_qb_user">
                    <group>
                        <group string="QuickBooks IDs">
                            <field name="qb_po_id" readonly="1"/>
                            <field name="qb_sync_token" readonly="1"/>
                        </group>
                        <group string="Sync Status">
                            <field name="qb_last_synced" readonly="1"/>
                            <field name="qb_do_not_sync"/>
                            <field name="qb_sync_error" readonly="1"
                                   invisible="not qb_sync_error"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
