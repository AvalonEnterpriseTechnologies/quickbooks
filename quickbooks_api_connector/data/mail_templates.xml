<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">
    <!--
        Permanent sync-queue failures are surfaced via a native
        ``mail.activity`` (warning To-do) on the underlying record,
        not via an outbound email. See
        ``quickbooks.sync.queue._raise_failure_activity``.
    -->

    <record id="mail_template_connection_error" model="mail.template">
        <field name="name">QuickBooks: Connection Error</field>
        <field name="model_id" ref="model_quickbooks_config"/>
        <field name="subject">QuickBooks Connection Error for {{ object.company_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ (object.company_id.email or '') }}</field>
        <field name="body_html"><![CDATA[
<div style="margin: 0px; padding: 0px;">
    <p>The QuickBooks connection for <strong>{{ object.company_id.name }}</strong>
       has encountered an error and syncing has been paused.</p>
    <p><strong>Error:</strong></p>
    <pre style="background: #f5f5f5; padding: 8px;">{{ object.error_message }}</pre>
    <p>Please reconnect QuickBooks from the Configuration page in Odoo.</p>
</div>
]]></field>
    </record>
</data>
</odoo>
