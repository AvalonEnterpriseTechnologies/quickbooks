<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_qb_snapshot" model="ir.actions.report">
        <field name="name">QuickBooks Report Snapshot</field>
        <field name="model">quickbooks.report.snapshot</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">quickbooks_api_connector.report_qb_snapshot</field>
        <field name="report_file">quickbooks_api_connector.report_qb_snapshot</field>
        <field name="print_report_name">'QuickBooks %s %s' % (object.report_type, object.period_end)</field>
    </record>

    <template id="report_qb_snapshot">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>
                            <span t-esc="doc.report_type"/>
                            <small t-if="doc.accounting_method">
                                (<span t-esc="doc.accounting_method"/>)
                            </small>
                        </h2>
                        <p>
                            <strong>Period:</strong>
                            <span t-esc="doc.period_start"/> - <span t-esc="doc.period_end"/>
                        </p>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Account / Section</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.row_ids.sorted(key=lambda r: (r.sequence, r.id))" t-as="row">
                                    <td>
                                        <span t-att-style="'padding-left:%spx' % (row.level * 18)">
                                            <strong t-if="row.is_total or row.is_section" t-esc="row.label"/>
                                            <span t-if="not (row.is_total or row.is_section)" t-esc="row.label"/>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % (row.amount or 0.0)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
