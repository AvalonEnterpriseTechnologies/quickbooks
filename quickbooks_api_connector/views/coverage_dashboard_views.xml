<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quickbooks_coverage_matrix_list" model="ir.ui.view">
        <field name="name">quickbooks.coverage.matrix.list</field>
        <field name="model">quickbooks.coverage.matrix</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Coverage Matrix">
                <field name="area"/>
                <field name="entity_type"/>
                <field name="status" widget="badge"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_quickbooks_dashboard_form" model="ir.ui.view">
        <field name="name">quickbooks.dashboard.form</field>
        <field name="model">quickbooks.dashboard</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Dashboard">
                <group>
                    <field name="company_id"/>
                    <field name="queue_depth"/>
                    <field name="failed_queue_count"/>
                    <field name="sync_success_24h"/>
                    <field name="sync_errors_24h"/>
                    <field name="last_successful_sync"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_quickbooks_coverage_matrix" model="ir.actions.act_window">
        <field name="name">QuickBooks Coverage Matrix</field>
        <field name="res_model">quickbooks.coverage.matrix</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_quickbooks_dashboard" model="ir.actions.act_window">
        <field name="name">QuickBooks Dashboard</field>
        <field name="res_model">quickbooks.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
