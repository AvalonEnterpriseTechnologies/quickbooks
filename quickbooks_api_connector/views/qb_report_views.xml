<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qb_report_snapshot_list" model="ir.ui.view">
        <field name="name">quickbooks.report.snapshot.list</field>
        <field name="model">quickbooks.report.snapshot</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Report Snapshots" default_order="period_end desc">
                <field name="report_type"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="accounting_method"/>
                <field name="schema_version"/>
                <field name="row_count"/>
                <field name="fetched_at"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_report_snapshot_form" model="ir.ui.view">
        <field name="name">quickbooks.report.snapshot.form</field>
        <field name="model">quickbooks.report.snapshot</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Report Snapshot" create="0" edit="0">
                <header>
                    <button name="action_print_qbo_report"
                            string="Print QBO Report"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_open_native_odoo_report"
                            string="Open in Native Odoo Reports"
                            type="object"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="accounting_method"/>
                        </group>
                        <group>
                            <field name="schema_version"/>
                            <field name="row_count"/>
                            <field name="fetched_at"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw JSON">
                            <field name="raw_json" nolabel="1" widget="json"/>
                        </page>
                        <page string="Rows">
                            <field name="row_ids" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qb_report_row_list" model="ir.ui.view">
        <field name="name">quickbooks.report.row.list</field>
        <field name="model">quickbooks.report.row</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Report Rows" default_order="snapshot_id, sequence">
                <field name="period_end"/>
                <field name="report_type"/>
                <field name="level"/>
                <field name="label"/>
                <field name="amount" sum="Amount"/>
                <field name="is_section"/>
                <field name="is_total"/>
                <field name="account_id"/>
                <field name="qb_account_id"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_report_row_form" model="ir.ui.view">
        <field name="name">quickbooks.report.row.form</field>
        <field name="model">quickbooks.report.row</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Report Row" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="label"/>
                            <field name="path"/>
                            <field name="level"/>
                            <field name="parent_id"/>
                            <field name="snapshot_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="is_section"/>
                            <field name="is_total"/>
                            <field name="account_id"/>
                            <field name="qb_account_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qb_account_balance_list" model="ir.ui.view">
        <field name="name">quickbooks.account.balance.list</field>
        <field name="model">quickbooks.account.balance</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Account Balances" default_order="period_end desc, account_name">
                <field name="period_end"/>
                <field name="report_type"/>
                <field name="account_name"/>
                <field name="account_id"/>
                <field name="qb_account_id"/>
                <field name="debit_balance" sum="Debit"/>
                <field name="credit_balance" sum="Credit"/>
                <field name="balance" sum="Balance"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_account_balance_form" model="ir.ui.view">
        <field name="name">quickbooks.account.balance.form</field>
        <field name="model">quickbooks.account.balance</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Account Balance" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="account_name"/>
                            <field name="account_id"/>
                            <field name="qb_account_id"/>
                            <field name="report_type"/>
                            <field name="period_end"/>
                        </group>
                        <group>
                            <field name="debit_balance"/>
                            <field name="credit_balance"/>
                            <field name="balance"/>
                            <field name="currency_id"/>
                            <field name="snapshot_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qb_journal_balance_list" model="ir.ui.view">
        <field name="name">quickbooks.journal.balance.list</field>
        <field name="model">quickbooks.journal.balance</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Journal Balances" default_order="period_end desc, journal_code">
                <field name="period_end"/>
                <field name="journal_code"/>
                <field name="journal_name"/>
                <field name="debit_balance" sum="Debit"/>
                <field name="credit_balance" sum="Credit"/>
                <field name="balance" sum="Balance"/>
                <field name="currency_id"/>
                <field name="snapshot_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_journal_balance_form" model="ir.ui.view">
        <field name="name">quickbooks.journal.balance.form</field>
        <field name="model">quickbooks.journal.balance</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Journal Balance" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="journal_code"/>
                            <field name="journal_name"/>
                            <field name="period_end"/>
                            <field name="accounting_method"/>
                        </group>
                        <group>
                            <field name="debit_balance"/>
                            <field name="credit_balance"/>
                            <field name="balance"/>
                            <field name="currency_id"/>
                            <field name="snapshot_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qb_partner_balance_list" model="ir.ui.view">
        <field name="name">quickbooks.partner.balance.list</field>
        <field name="model">quickbooks.partner.balance</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Partner Balances" default_order="period_end desc, partner_name">
                <field name="period_end"/>
                <field name="kind"/>
                <field name="partner_name"/>
                <field name="partner_id"/>
                <field name="total" sum="Total"/>
                <field name="bucket_current" sum="Current"/>
                <field name="bucket_1_30" sum="1-30"/>
                <field name="bucket_31_60" sum="31-60"/>
                <field name="bucket_61_90" sum="61-90"/>
                <field name="bucket_over_90" sum="90+"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_inventory_balance_list" model="ir.ui.view">
        <field name="name">quickbooks.inventory.balance.list</field>
        <field name="model">quickbooks.inventory.balance</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Inventory Valuation" default_order="period_end desc, product_name">
                <field name="period_end"/>
                <field name="product_name"/>
                <field name="product_id"/>
                <field name="qb_item_id"/>
                <field name="qty_on_hand" sum="Quantity"/>
                <field name="avg_cost"/>
                <field name="value" sum="Value"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_tax_liability_list" model="ir.ui.view">
        <field name="name">quickbooks.tax.liability.list</field>
        <field name="model">quickbooks.tax.liability</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Tax Liabilities" default_order="period_end desc, tax_agency">
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="tax_agency"/>
                <field name="tax_id"/>
                <field name="taxable_amount" sum="Taxable"/>
                <field name="tax_amount" sum="Tax"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_balance_variance_list" model="ir.ui.view">
        <field name="name">quickbooks.balance.variance.list</field>
        <field name="model">quickbooks.balance.variance</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Balance Variances" default_order="period_end desc, abs_variance desc">
                <field name="period_end"/>
                <field name="label"/>
                <field name="account_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="qb_amount" sum="QBO"/>
                <field name="odoo_amount" sum="Odoo"/>
                <field name="variance" sum="Variance"/>
                <field name="variance_pct"/>
                <field name="threshold_breached"/>
                <field name="currency_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_balance_variance_pivot" model="ir.ui.view">
        <field name="name">quickbooks.balance.variance.pivot</field>
        <field name="model">quickbooks.balance.variance</field>
        <field name="arch" type="xml">
            <pivot string="QuickBooks Balance Variances">
                <field name="period_end" type="row"/>
                <field name="label" type="row"/>
                <field name="qb_amount" type="measure"/>
                <field name="odoo_amount" type="measure"/>
                <field name="variance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_qb_report_snapshots" model="ir.actions.act_window">
        <field name="name">QuickBooks Report Snapshots</field>
        <field name="res_model">quickbooks.report.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_account_balances" model="ir.actions.act_window">
        <field name="name">QuickBooks Account Balances</field>
        <field name="res_model">quickbooks.account.balance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_journal_balances" model="ir.actions.act_window">
        <field name="name">QuickBooks Journal Balances</field>
        <field name="res_model">quickbooks.journal.balance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_partner_balances" model="ir.actions.act_window">
        <field name="name">QuickBooks AR/AP Aging</field>
        <field name="res_model">quickbooks.partner.balance</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_qb_inventory_balances" model="ir.actions.act_window">
        <field name="name">QuickBooks Inventory Valuation</field>
        <field name="res_model">quickbooks.inventory.balance</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_qb_tax_liabilities" model="ir.actions.act_window">
        <field name="name">QuickBooks Tax Liabilities</field>
        <field name="res_model">quickbooks.tax.liability</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_qb_balance_variances" model="ir.actions.act_window">
        <field name="name">QuickBooks Balance Variances</field>
        <field name="res_model">quickbooks.balance.variance</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('threshold_breached', '=', True)]</field>
    </record>

    <record id="action_qb_balance_sheet_rows" model="ir.actions.act_window">
        <field name="name">QuickBooks Balance Sheet</field>
        <field name="res_model">quickbooks.report.row</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('report_type', '=', 'BalanceSheet')]</field>
    </record>

    <record id="action_qb_profit_loss_rows" model="ir.actions.act_window">
        <field name="name">QuickBooks Profit and Loss</field>
        <field name="res_model">quickbooks.report.row</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('report_type', '=', 'ProfitAndLoss')]</field>
    </record>

    <record id="action_qb_trial_balance_rows" model="ir.actions.act_window">
        <field name="name">QuickBooks Trial Balance</field>
        <field name="res_model">quickbooks.report.row</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('report_type', '=', 'TrialBalance')]</field>
    </record>

    <record id="action_qb_general_ledger_rows" model="ir.actions.act_window">
        <field name="name">QuickBooks General Ledger</field>
        <field name="res_model">quickbooks.report.row</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('report_type', '=', 'GeneralLedger')]</field>
    </record>

    <menuitem id="menu_qb_accounting_reports_root"
              name="QuickBooks Reports"
              parent="account.menu_finance"
              sequence="95"
              groups="quickbooks_api_connector.group_qb_user"/>
    <menuitem id="menu_qb_report_snapshots"
              name="Snapshots"
              parent="menu_qb_accounting_reports_root"
              sequence="10"
              action="action_qb_report_snapshots"/>
    <menuitem id="menu_qb_balance_sheet_rows"
              name="Balance Sheet"
              parent="menu_qb_accounting_reports_root"
              sequence="11"
              action="action_qb_balance_sheet_rows"/>
    <menuitem id="menu_qb_profit_loss_rows"
              name="Profit and Loss"
              parent="menu_qb_accounting_reports_root"
              sequence="12"
              action="action_qb_profit_loss_rows"/>
    <menuitem id="menu_qb_trial_balance_rows"
              name="Trial Balance"
              parent="menu_qb_accounting_reports_root"
              sequence="13"
              action="action_qb_trial_balance_rows"/>
    <menuitem id="menu_qb_general_ledger_rows"
              name="General Ledger"
              parent="menu_qb_accounting_reports_root"
              sequence="14"
              action="action_qb_general_ledger_rows"/>
    <menuitem id="menu_qb_account_balances"
              name="Account Balances"
              parent="menu_qb_accounting_reports_root"
              sequence="20"
              action="action_qb_account_balances"/>
    <menuitem id="menu_qb_journal_balances"
              name="Journal Balances"
              parent="menu_qb_accounting_reports_root"
              sequence="30"
              action="action_qb_journal_balances"/>
    <menuitem id="menu_qb_partner_balances"
              name="AR/AP Aging"
              parent="menu_qb_accounting_reports_root"
              sequence="40"
              action="action_qb_partner_balances"/>
    <menuitem id="menu_qb_inventory_balances"
              name="Inventory Valuation"
              parent="menu_qb_accounting_reports_root"
              sequence="50"
              action="action_qb_inventory_balances"/>
    <menuitem id="menu_qb_tax_liabilities"
              name="Tax Liabilities"
              parent="menu_qb_accounting_reports_root"
              sequence="60"
              action="action_qb_tax_liabilities"/>
    <menuitem id="menu_qb_balance_variances"
              name="Balance Variances"
              parent="menu_qb_accounting_reports_root"
              sequence="70"
              action="action_qb_balance_variances"/>
</odoo>
