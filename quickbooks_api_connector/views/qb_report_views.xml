<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qb_balance_variance_list" model="ir.ui.view">
        <field name="name">qb.balance.variance.list</field>
        <field name="model">qb.balance.variance</field>
        <field name="arch" type="xml">
            <list string="QBO Balance Variances" default_order="period_end desc, abs_variance desc">
                <field name="period_end"/>
                <field name="report_type"/>
                <field name="label"/>
                <field name="account_id"/>
                <field name="qb_amount" sum="QBO"/>
                <field name="odoo_amount" sum="Odoo"/>
                <field name="variance" sum="Variance"/>
                <field name="threshold_breached"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_qb_balance_variance_form" model="ir.ui.view">
        <field name="name">qb.balance.variance.form</field>
        <field name="model">qb.balance.variance</field>
        <field name="arch" type="xml">
            <form string="QBO Balance Variance" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="accounting_method"/>
                            <field name="label"/>
                            <field name="account_id"/>
                        </group>
                        <group>
                            <field name="qb_amount"/>
                            <field name="odoo_amount"/>
                            <field name="variance"/>
                            <field name="abs_variance"/>
                            <field name="variance_pct"/>
                            <field name="threshold_breached"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw QBO Report">
                            <field name="raw_json" nolabel="1" widget="json" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qb_balance_variances" model="ir.actions.act_window">
        <field name="name">QBO Balance Variances</field>
        <field name="res_model">qb.balance.variance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qb_balance_variances"
              name="Balance Variances"
              parent="menu_qb_technical_root"
              sequence="28"
              action="action_qb_balance_variances"/>
</odoo>
