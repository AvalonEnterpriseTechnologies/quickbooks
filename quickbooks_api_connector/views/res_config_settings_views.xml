<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_quickbooks" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.quickbooks.sync_only</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="QuickBooks" name="quickbooks_api_connector"
                     groups="quickbooks_api_connector.group_qb_manager">

                    <field name="qb_config_id" invisible="1"/>
                    <field name="qb_state" invisible="1"/>
                    <field name="qb_company_name" invisible="1"/>
                    <field name="qb_last_sync_date" invisible="1"/>
                    <field name="qb_oauth_redirect_uri" invisible="1"/>
                    <field name="qb_webhook_endpoint_url" invisible="1"/>

                    <div class="alert alert-success" role="alert"
                         invisible="qb_state != 'connected'">
                        Connected to QuickBooks Online
                        <field name="qb_company_name" invisible="not qb_company_name"
                               nolabel="1" readonly="1" class="fw-bold ms-1"/>
                    </div>

                    <div class="alert alert-danger" role="alert"
                         invisible="qb_state != 'error'">
                        <i class="fa fa-exclamation-triangle"/>
                        QuickBooks connection error.
                        <field name="qb_error_message" invisible="not qb_error_message"
                               nolabel="1" readonly="1" class="d-block mt-1 small"/>
                    </div>

                    <div class="alert alert-secondary" role="alert"
                         invisible="qb_state == 'connected'">
                        QuickBooks is ready to connect. Enter your Intuit
                        Developer credentials below, then click
                        <strong>Connect to QuickBooks</strong>.
                    </div>

                    <div class="row mt16 o_settings_container">

                        <div class="col-12 o_setting_box"
                             invisible="qb_state == 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">API Credentials</span>
                                <div class="text-muted small mb8">
                                    From the Intuit Developer Portal &gt; Keys
                                    and credentials. Use the Sandbox keys for
                                    Development.
                                </div>
                                <div class="content-group">
                                    <field name="qb_environment"/>
                                    <field name="qb_client_id"
                                           placeholder="Your Intuit app Client ID"/>
                                    <field name="qb_client_secret" password="True"
                                           placeholder="Your Intuit app Client Secret"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div class="mb8">
                                    Last sync:
                                    <field name="qb_last_sync_date" nolabel="1" readonly="1"
                                           widget="datetime" class="d-inline"/>
                                </div>
                                <button name="action_qb_connect"
                                        string="Connect to QuickBooks"
                                        type="object" class="btn-primary me-2"
                                        invisible="qb_state == 'connected'"/>
                                <button name="action_qb_validate_setup"
                                        string="Test Setup in Odoo"
                                        type="object" class="btn-secondary me-2"/>
                                <button name="action_qb_test_connection"
                                        string="Test Company Connection"
                                        type="object" class="btn-secondary me-2"
                                        invisible="qb_state != 'connected'"/>
                                <button name="action_qb_sync_now"
                                        string="Sync Now"
                                        type="object" class="btn-primary me-2"
                                        icon="fa-refresh"
                                        invisible="qb_state != 'connected'"/>
                                <button name="action_qb_run_pending_jobs_now"
                                        string="Run Pending Jobs Now"
                                        type="object" class="btn-secondary me-2"
                                        icon="fa-play"
                                        invisible="qb_state != 'connected'"/>
                                <button name="action_qb_run_initial_migration"
                                        string="Run Initial Migration"
                                        type="object" class="btn-secondary me-2"
                                        icon="fa-cloud-download"
                                        invisible="qb_state != 'connected'"
                                        confirm="This will queue a full bidirectional sync of every enabled entity. Continue?"/>
                                <button name="action_qb_disconnect"
                                        string="Disconnect"
                                        type="object" class="btn-secondary"
                                        invisible="qb_state != 'connected'"
                                        confirm="Disconnect from QuickBooks?"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="qb_oauth_redirect_uri"
                                       string="OAuth Redirect URI"/>
                                <div class="text-muted small mb8">
                                    Add this exact URI under Intuit Developer &gt; Keys
                                    and credentials &gt; Redirect URIs before clicking
                                    Connect to QuickBooks. Do not paste this into
                                    the Webhooks tab.
                                </div>
                                <field name="qb_oauth_redirect_uri" readonly="1"
                                       widget="CopyClipboardChar"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="qb_webhook_endpoint_url"
                                       string="Webhook Setup"/>
                                <div class="text-muted small mb8">
                                    Paste this URL into Intuit's Webhooks tab, then paste
                                    the returned Verifier Token here.
                                </div>
                                <field name="qb_webhook_endpoint_url" readonly="1"
                                       widget="CopyClipboardChar"/>
                                <field name="qb_webhook_verifier_token" password="True"
                                       placeholder="Paste the verifier token from Intuit's Webhooks tab"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Sync Status</span>
                                <div class="text-muted small mb8">
                                    Live counters from <code>quickbooks.sync.queue</code>
                                    and <code>quickbooks.sync.log</code>. Per-record sync
                                    history is posted to each Odoo record's chatter.
                                    Permanent failures raise a To-do activity on the
                                    affected record assigned to the QuickBooks Manager
                                    group.
                                </div>
                                <div class="content-group">
                                    <field name="qb_queue_depth" readonly="1"/>
                                    <field name="qb_failed_queue_count" readonly="1"/>
                                    <field name="qb_sync_success_24h" readonly="1"/>
                                    <field name="qb_sync_errors_24h" readonly="1"/>
                                    <field name="qb_last_successful_sync" readonly="1"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Chart Of Accounts Strategy</span>
                                <div class="text-muted small mb8">
                                    <b>Map Only</b> keeps the existing Odoo
                                    chart of accounts intact: QBO accounts are
                                    linked to existing Odoo accounts by code,
                                    then by name; anything that fails to match
                                    is logged on this configuration's chatter
                                    and raises a warning activity for the
                                    QuickBooks Manager group. Map the
                                    remaining accounts manually by pasting
                                    the QBO ID onto the matching Odoo account.
                                    Use <b>Create Missing</b> only if you want
                                    QBO to seed the Odoo chart of accounts.
                                </div>
                                <field name="qb_account_strategy"/>
                                <div class="content-group mt8">
                                    <field name="qb_auto_apply_account_mapping"/>
                                </div>
                                <div class="text-muted small mb8">
                                    When <b>Auto-Apply QBO Account Mapping On
                                    Sync</b> is on (default), every Sync Now
                                    automatically runs <i>Apply QBO Account
                                    Mapping</i> after the chart of accounts
                                    pull, so bills, invoices, payments, and
                                    journal entries always find a destination
                                    Odoo account. Disable only when you want
                                    to review the discovery report before
                                    linking.
                                </div>
                                <div class="content-group mt8">
                                    <field name="qb_account_last_discovery" readonly="1"/>
                                    <field name="qb_account_discovered_count" readonly="1"/>
                                    <field name="qb_account_mapped_count" readonly="1"/>
                                    <field name="qb_account_unmapped_count" readonly="1"/>
                                </div>
                                <button name="action_qb_preview_accounts"
                                        string="Preview QBO Account Mapping"
                                        type="object" class="btn-secondary me-2 mt8"
                                        icon="fa-search"/>
                                <button name="action_qb_apply_account_mapping"
                                        string="Apply QBO Account Mapping"
                                        type="object" class="btn-primary me-2 mt8"
                                        icon="fa-link"
                                        confirm="Link matched QBO accounts onto the existing Odoo chart of accounts now. No new Odoo accounts will be created. Continue?"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane">
                                <field name="qb_auto_push_transfers"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qb_auto_push_transfers"
                                       string="Auto-push Transfers to QBO"/>
                                <div class="text-muted small mb8">
                                    Leave <b>off</b> while migrating from
                                    QuickBooks to Odoo. When off, the
                                    connector never automatically enqueues
                                    a Transfer push job — operators trigger
                                    each push from the journal entry's
                                    <i>Action &#9662; QuickBooks: Push Transfer
                                    to QuickBooks</i> menu, which refuses
                                    if either bank account is unmapped.
                                    This prevents the runaway "FromAccountRef
                                    missing" 400-error loop that QBO returns
                                    when bank accounts are not yet linked.
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane">
                                <field name="qb_auto_post_pulled_records"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qb_auto_post_pulled_records"
                                       string="Auto-Post Pulled Records"/>
                                <div class="text-muted small mb8">
                                    QBO transactions (invoices, bills, vendor
                                    credits, journal entries, payments) are
                                    always posted on the QuickBooks side. When
                                    enabled, the connector posts each freshly
                                    pulled record in Odoo so it lands in
                                    state <b>Posted</b> instead of
                                    <b>Draft</b>. Auto-post failures are
                                    captured on the record's
                                    <code>qb_sync_error</code> without
                                    breaking the rest of the sync. Turn off
                                    when you want to review every imported
                                    record before posting.
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane">
                                <field name="qb_sync_reports"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qb_sync_reports" string="Financial Reports"/>
                                <div class="text-muted small mb8">
                                    Pull Balance Sheet, Profit and Loss, Trial Balance,
                                    and General Ledger snapshots from QBO.
                                </div>
                                <field name="qb_reports_method"/>
                                <field name="qb_reports_history_months"/>
                                <field name="qb_reports_keep_n"/>
                                <field name="qb_reports_use_v2_now"/>
                                <field name="qb_sync_recurring_transactions"/>
                                <field name="qb_custom_fields_enabled"/>
                                <field name="qb_sync_employee_benefits"/>
                                <field name="qb_sync_payroll_settings"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane">
                                <field name="qb_payroll_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qb_payroll_enabled" string="QuickBooks Payroll"/>
                                <div class="text-muted small mb8">
                                    Pull employees, pay schedules, pay items, tax setup,
                                    compensations, and historical paychecks from the QBO
                                    Payroll GraphQL API. Paychecks land in the read-only
                                    qb.payroll.check archive so Odoo Payroll can take over
                                    as the live system of record without colliding.
                                </div>
                                <div class="content-group" invisible="not qb_payroll_enabled">
                                    <field name="qb_sync_payroll_pay_schedules"/>
                                    <field name="qb_sync_payroll_pay_items"/>
                                    <field name="qb_sync_payroll_employees_detail"/>
                                    <field name="qb_sync_payroll_tax_setup"/>
                                    <field name="qb_sync_payroll_compensations"/>
                                    <field name="qb_sync_payroll_checks_history"/>
                                    <field name="qb_sync_payroll_payslips"/>
                                    <field name="qb_payroll_post_archive_journal"/>
                                </div>
                                <div class="content-group mt8"
                                     invisible="not qb_payroll_enabled">
                                    <field name="qb_payroll_archived" readonly="1"/>
                                    <field name="qb_payroll_cutover_date" readonly="1"/>
                                </div>
                                <button name="action_qb_enable_payroll_all"
                                        string="Enable QuickBooks Payroll (All Features)"
                                        type="object" class="btn-primary me-2 mt8"
                                        icon="fa-bolt"
                                        confirm="Install hr_payroll + l10n_us_hr_payroll + l10n_us_hr_payroll_ks + the QBO HR bridges, enable every payroll sync toggle, and run the orchestrator pull immediately. Continue?"/>
                                <button name="action_qb_cutover_payroll"
                                        string="Cutover To Odoo Payroll"
                                        type="object" class="btn-secondary me-2 mt8"
                                        icon="fa-flag-checkered"
                                        invisible="not qb_payroll_enabled or qb_payroll_archived"
                                        confirm="Run pre-cutover audit and (if clean) seal QuickBooks Payroll as a read-only archive. Continue?"/>
                                <button name="action_qb_payroll_audit_only"
                                        string="Pre-Cutover Audit"
                                        type="object" class="btn-secondary me-2 mt8"
                                        icon="fa-stethoscope"
                                        invisible="not qb_payroll_enabled or qb_payroll_archived"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Coverage</span>
                                <div class="text-muted small mb8">
                                    QBO entities supported by this connector.
                                </div>
                                <field name="qb_coverage_summary" readonly="1"
                                       widget="text" nolabel="1"/>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box"
                             invisible="qb_state != 'connected'">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Sales Document Migration Integrity</span>
                                <div class="text-muted small mb8">
                                    Latest counters from qb.sales.doc.relinker — Estimate, Invoice,
                                    Credit Memo, Sales Receipt, and Refund Receipt records pulled
                                    from QBO, how many were linked back to their parent doc, how
                                    many remain orphan, and total amounts on both sides for
                                    reconciliation.
                                </div>
                                <field name="qb_sales_doc_integrity_summary"
                                       readonly="1" widget="text" nolabel="1"/>
                            </div>
                        </div>

                    </div>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
