<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_quickbooks" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.quickbooks.sync_only</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="QuickBooks" name="quickbooks_api_connector"
                     groups="quickbooks_api_connector.group_qb_manager">

                    <field name="qb_config_id" invisible="1"/>
                    <field name="qb_state" invisible="1"/>
                    <field name="qb_company_name" invisible="1"/>
                    <field name="qb_last_sync_date" invisible="1"/>

                    <div class="alert alert-success" role="alert"
                         invisible="qb_state != 'connected'">
                        Connected to QuickBooks Online
                        <field name="qb_company_name" invisible="not qb_company_name"
                               nolabel="1" readonly="1" class="fw-bold ms-1"/>
                    </div>

                    <div class="alert alert-secondary" role="alert"
                         invisible="qb_state == 'connected'">
                        QuickBooks is ready to connect. The one-time setup wizard
                        will collect credentials if they are not already configured.
                    </div>

                    <div class="row mt16 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div class="mb8">
                                    Last sync:
                                    <field name="qb_last_sync_date" nolabel="1" readonly="1"
                                           widget="datetime" class="d-inline"/>
                                </div>
                                <button name="action_qb_connect"
                                        string="Connect to QuickBooks"
                                        type="object" class="btn-primary me-2"
                                        invisible="qb_state == 'connected'"/>
                                <button name="action_qb_sync_now"
                                        string="Sync Now"
                                        type="object" class="btn-primary me-2"
                                        icon="fa-refresh"
                                        invisible="qb_state != 'connected'"/>
                                <button name="action_qb_disconnect"
                                        string="Disconnect"
                                        type="object" class="btn-secondary"
                                        invisible="qb_state != 'connected'"
                                        confirm="Disconnect from QuickBooks?"/>
                            </div>
                        </div>
                    </div>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
