<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_qb_payroll_employee" model="ir.actions.act_window">
        <field name="name">Payroll Employees</field>
        <field name="res_model">quickbooks.payroll.employee</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_payroll_pay_item" model="ir.actions.act_window">
        <field name="name">Payroll Pay Items</field>
        <field name="res_model">quickbooks.payroll.pay.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_payroll_pay_schedule" model="ir.actions.act_window">
        <field name="name">Payroll Pay Schedules</field>
        <field name="res_model">quickbooks.payroll.pay.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_payroll_check" model="ir.actions.act_window">
        <field name="name">Payroll Checks</field>
        <field name="res_model">quickbooks.payroll.check</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qb_work_location" model="ir.actions.act_window">
        <field name="name">Work Locations</field>
        <field name="res_model">quickbooks.work.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qb_payroll_root"
              name="Payroll"
              parent="menu_qb_technical_root"
              sequence="35"
              groups="quickbooks_api_connector.group_qb_manager"/>

    <menuitem id="menu_qb_payroll_employee"
              name="Employees"
              parent="menu_qb_payroll_root"
              sequence="10"
              action="action_qb_payroll_employee"/>

    <menuitem id="menu_qb_payroll_pay_schedule"
              name="Pay Schedules"
              parent="menu_qb_payroll_root"
              sequence="20"
              action="action_qb_payroll_pay_schedule"/>

    <menuitem id="menu_qb_payroll_pay_item"
              name="Pay Items"
              parent="menu_qb_payroll_root"
              sequence="30"
              action="action_qb_payroll_pay_item"/>

    <menuitem id="menu_qb_payroll_check"
              name="Checks"
              parent="menu_qb_payroll_root"
              sequence="40"
              action="action_qb_payroll_check"/>

    <menuitem id="menu_qb_work_location"
              name="Work Locations"
              parent="menu_qb_payroll_root"
              sequence="50"
              action="action_qb_work_location"/>
</odoo>
