<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_qb" model="ir.ui.view">
        <field name="name">account.move.form.qb</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="QuickBooks" name="quickbooks_tab"
                      groups="quickbooks_api_connector.group_qb_user">
                    <group>
                        <group string="QuickBooks IDs">
                            <field name="qb_invoice_id" readonly="1"
                                   invisible="move_type not in ('out_invoice', 'out_refund')"/>
                            <field name="qb_bill_id" readonly="1"
                                   invisible="move_type != 'in_invoice'"/>
                            <field name="qb_creditmemo_id" readonly="1"
                                   invisible="move_type != 'out_refund'"/>
                            <field name="qb_je_id" readonly="1"
                                   invisible="move_type != 'entry'"/>
                            <field name="qb_salesreceipt_id" readonly="1"
                                   invisible="not qb_salesreceipt_id"/>
                            <field name="qb_deposit_id" readonly="1"
                                   invisible="not qb_deposit_id"/>
                            <field name="qb_transfer_id" readonly="1"
                                   invisible="not qb_transfer_id"/>
                            <field name="qb_refundreceipt_id" readonly="1"
                                   invisible="not qb_refundreceipt_id"/>
                            <field name="qb_vendorcredit_id" readonly="1"
                                   invisible="not qb_vendorcredit_id"/>
                            <field name="qb_sync_token" readonly="1"/>
                        </group>
                        <group string="Sync Status">
                            <field name="qb_last_synced" readonly="1"/>
                            <field name="qb_do_not_sync"/>
                            <field name="qb_sync_error" readonly="1"
                                   invisible="not qb_sync_error"/>
                        </group>
                    </group>
                    <div>
                        <button name="action_sync_to_qb"
                                string="Sync to QuickBooks"
                                type="object"
                                class="btn-primary"
                                groups="quickbooks_api_connector.group_qb_user"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
