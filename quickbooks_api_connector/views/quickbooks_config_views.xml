<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         QuickBooks — simplified config form (API credentials only)
         ══════════════════════════════════════════════════════════ -->
    <record id="view_quickbooks_config_form" model="ir.ui.view">
        <field name="name">quickbooks.config.form</field>
        <field name="model">quickbooks.config</field>
        <field name="arch" type="xml">
            <form string="QuickBooks Configuration">
                <header>
                    <button name="action_connect_qb"
                            string="Connect to QuickBooks"
                            type="object" class="btn-primary"
                            icon="fa-plug"
                            invisible="state != 'draft'"/>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object" class="btn-secondary"
                            icon="fa-refresh"
                            invisible="state != 'connected'"/>
                    <button name="action_disconnect"
                            string="Disconnect"
                            type="object" class="btn-danger"
                            icon="fa-times"
                            invisible="state == 'draft'"
                            confirm="Disconnect from QuickBooks?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,connected"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1>QuickBooks Online</h1>
                    </div>

                    <div class="alert alert-success" role="alert"
                         invisible="state != 'connected'">
                        <i class="fa fa-check-circle"/> Connected
                        <span invisible="not qb_company_name"> to <strong><field name="qb_company_name" nolabel="1" readonly="1"/></strong></span>.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="state != 'error'">
                        <i class="fa fa-exclamation-triangle"/> Connection error — check your credentials and try again.
                        <div invisible="not error_message"
                             class="mt-1 small text-muted">
                            <field name="error_message" nolabel="1" readonly="1"/>
                        </div>
                    </div>

                    <group string="API Credentials">
                        <field name="client_id" placeholder="Your Intuit app Client ID"
                               required="1"/>
                        <field name="client_secret" password="True"
                               placeholder="Your Intuit app Client Secret"
                               required="1"/>
                        <field name="environment" required="1"/>
                    </group>

                    <group string="Connection Info"
                           invisible="state == 'draft'">
                        <field name="realm_id" readonly="1"/>
                        <field name="last_sync_date" readonly="1"/>
                    </group>

                    <notebook groups="quickbooks_api_connector.group_qb_manager">
                        <page string="Sync Defaults">
                            <group>
                                <field name="conflict_resolution"/>
                                <field name="auto_sync_interval"/>
                                <field name="auto_sync_interval_type"/>
                            </group>
                            <group string="Core Entities">
                                <group>
                                    <field name="sync_customers"/>
                                    <field name="sync_vendors"/>
                                    <field name="sync_products"/>
                                    <field name="sync_invoices"/>
                                    <field name="sync_bills"/>
                                    <field name="sync_payments"/>
                                </group>
                                <group>
                                    <field name="sync_journal_entries"/>
                                    <field name="sync_credit_memos"/>
                                    <field name="sync_estimates"/>
                                    <field name="sync_tax_codes"/>
                                    <field name="sync_vendor_credits"/>
                                    <field name="sync_refund_receipts"/>
                                </group>
                            </group>
                            <group string="Extended Entities">
                                <group>
                                    <field name="sync_purchase_orders"/>
                                    <field name="sync_sales_receipts"/>
                                    <field name="sync_expenses"/>
                                    <field name="sync_deposits"/>
                                    <field name="sync_transfers"/>
                                    <field name="sync_classes"/>
                                </group>
                                <group>
                                    <field name="sync_terms"/>
                                    <field name="sync_employees"/>
                                    <field name="sync_departments"/>
                                    <field name="sync_time_activities"/>
                                    <field name="sync_projects"/>
                                    <field name="sync_inventory_qty"/>
                                    <field name="sync_inventory_adjustments"/>
                                    <field name="sync_inventory_valuation_accounts"/>
                                    <field name="qb_default_warehouse_id"/>
                                    <field name="sync_attachments"/>
                                </group>
                            </group>
                            <group string="Advanced APIs">
                                <field name="payroll_enabled"/>
                                <field name="payroll_create_draft_payslips"/>
                                <field name="qbt_enabled"/>
                            </group>
                        </page>
                    </notebook>

                    <group invisible="1">
                        <field name="company_id"/>
                        <field name="webhook_verifier_token"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_quickbooks_config_list" model="ir.ui.view">
        <field name="name">quickbooks.config.list</field>
        <field name="model">quickbooks.config</field>
        <field name="arch" type="xml">
            <list string="QuickBooks Configurations">
                <field name="company_id"/>
                <field name="environment"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'connected'"
                       decoration-danger="state == 'error'"
                       decoration-muted="state == 'draft'"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="action_quickbooks_config" model="ir.actions.act_window">
        <field name="name">QuickBooks Configuration</field>
        <field name="res_model">quickbooks.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
