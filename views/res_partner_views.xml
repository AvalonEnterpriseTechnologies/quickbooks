<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_qb" model="ir.ui.view">
        <field name="name">res.partner.form.qb</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="QuickBooks" name="quickbooks_tab"
                      groups="quickbooks_api_module.group_qb_user">
                    <group>
                        <group string="QuickBooks IDs">
                            <field name="qb_customer_id" readonly="1"/>
                            <field name="qb_vendor_id" readonly="1"/>
                            <field name="qb_sync_token" readonly="1"/>
                        </group>
                        <group string="Sync Status">
                            <field name="qb_last_synced" readonly="1"/>
                            <field name="qb_do_not_sync"/>
                            <field name="qb_sync_error" readonly="1"
                                   invisible="not qb_sync_error"/>
                        </group>
                    </group>
                    <div>
                        <button name="action_sync_to_qb"
                                string="Sync to QuickBooks"
                                type="object"
                                class="btn-primary"
                                groups="quickbooks_api_module.group_qb_user"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
