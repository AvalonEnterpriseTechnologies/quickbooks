<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Client action that launches the OWL dashboard -->
    <record id="miltech_dashboard_action" model="ir.actions.client">
        <field name="name">Miltech Dashboard</field>
        <field name="tag">miltech_report.Dashboard</field>
    </record>

    <!-- Menu item under CRM > Reporting -->
    <menuitem
        id="miltech_dashboard_menu"
        name="Miltech Dashboard"
        parent="crm.crm_menu_report"
        action="miltech_dashboard_action"
        sequence="99"/>

</odoo>
