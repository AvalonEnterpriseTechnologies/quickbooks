<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="miltech_paperformat_letter" model="report.paperformat">
        <field name="name">Miltech US Letter</field>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="action_miltech_pdf_report" model="ir.actions.report">
        <field name="name">Miltech CRM Dashboard PDF</field>
        <field name="model">miltech.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">miltech_report.report_miltech_dashboard</field>
        <field name="report_file">miltech_report.report_miltech_dashboard</field>
        <field name="paperformat_id" ref="miltech_paperformat_letter"/>
        <field name="print_report_name">'Miltech_CRM_Report'</field>
    </record>

</odoo>
