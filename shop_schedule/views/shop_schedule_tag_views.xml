<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="shop_schedule_tag_view_list" model="ir.ui.view">
        <field name="name">shop.schedule.tag.list</field>
        <field name="model">shop.schedule.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="shop_schedule_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">shop.schedule.tag</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
