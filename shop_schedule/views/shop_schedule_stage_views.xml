<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="shop_schedule_stage_view_list" model="ir.ui.view">
        <field name="name">shop.schedule.stage.list</field>
        <field name="model">shop.schedule.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="shop_schedule_stage_view_form" model="ir.ui.view">
        <field name="name">shop.schedule.stage.form</field>
        <field name="model">shop.schedule.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="fold"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="shop_schedule_stage_action" model="ir.actions.act_window">
        <field name="name">Stages</field>
        <field name="res_model">shop.schedule.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
